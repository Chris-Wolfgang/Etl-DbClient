root = false

# Source generators are highly mechanical, string-heavy code that doesn't fit
# the same hygiene bar as runtime library code. Relax the rules that fire
# noisily here without protecting us from real bugs.
[*.cs]
dotnet_diagnostic.MA0006.severity = none   # string == operator (we compare metadata strings constantly)
dotnet_diagnostic.MA0051.severity = none   # method too long (Extract / Emit are long by design)
dotnet_diagnostic.S3358.severity  = none   # nested ternary (acceptable in record-building paths)
dotnet_diagnostic.S3267.severity  = none   # collection LINQ (clarity > microbenchmarks at gen time)
dotnet_diagnostic.S3398.severity  = none   # move private to nested type (Emit / Extract are intentional outer methods)
dotnet_diagnostic.S1135.severity  = none   # TODO comments (intentional follow-up markers — Update/Delete/Select gen)
dotnet_diagnostic.S2094.severity  = none   # empty class (IsExternalInit polyfill is a marker type by design)
dotnet_diagnostic.RS0016.severity = none   # PublicApiAnalyzers — this assembly ships as an analyzer DLL, never directly referenced by consumers, so the PublicAPI manifest contract doesn't apply
dotnet_diagnostic.RS0017.severity = none   # same reason — assembly is consumed only via the Roslyn analyzer host, not as a NuGet PackageReference
dotnet_diagnostic.RS0037.severity = none   # same — nullable annotation tracking on the manifest is moot when there's no manifest
