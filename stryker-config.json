{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-net/master/src/Stryker.Core/Stryker.Core/stryker-schema.json",
  "stryker-config": {
    "project": "src/Wolfgang.Etl.DbClient/Wolfgang.Etl.DbClient.csproj",
    "target-framework": "net10.0",
    "test-projects": [
      "tests/Wolfgang.Etl.DbClient.Tests.Unit/Wolfgang.Etl.DbClient.Tests.Unit.csproj"
    ],
    "reporters": [
      "progress",
      "html",
      "json",
      "cleartext",
      "cleartext-tree"
    ],
    "mutation-level": "Standard",
    "concurrency": 4,
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 0
    },
    "mutate": [
      "!**/GlobalUsings.cs",
      "!**/AssemblyAttributes.cs",
      "!**/IsExternalInit.cs"
    ]
  }
}
