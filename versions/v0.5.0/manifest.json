        }
      },
      "version": "",
      "Uid": null,
      "IsMRef": true,
      "Title": "Wolfgang.Etl.DbClient.DbColumnAttribute",
      "Summary": "<p sourcefile=\"api/Wolfgang.Etl.DbClient.DbColumnAttribute.yml\" sourcestartlinenumber=\"1\">Optional per-property override for a <xref href=\"Wolfgang.Etl.DbClient.DbTableAttribute\" data-throw-if-not-resolved=\"false\"></xref>-decorated\nrecord. Maps the annotated property to a column whose name differs from\nthe property name, or marks it as <xref href=\"Wolfgang.Etl.DbClient.DbColumnAttribute.Skip\" data-throw-if-not-resolved=\"false\"></xref>ped from the\ngenerated SQL.</p>\n"
    },
    {
